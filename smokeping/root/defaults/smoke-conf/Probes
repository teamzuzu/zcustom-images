*** Probes ***

+ FPing
binary = /usr/sbin/fping
offset = random
pings = 5
step = 20

+ AnotherCurl
binary = /usr/bin/curl
forks = 5
offset = random
step = 60
pings = 5
urlformat = https://%host%/
extraargs = -s

+ TCPPing
step = 60
binary = /usr/bin/tcpping
forks = 5
offset = random
pings = 5
port = 80

